# Vaidya AI Platform - Environment Variables
# Copy this file to .env.local for local development
# For Vercel deployment, add these variables in the Vercel Dashboard

# Google Gemini API Key (required for Gemini-powered features)
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Key (required for Groq-powered features)
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional: Custom ping message for health checks
PING_MESSAGE=ping

