{
  "version": 2,
  "installCommand": "npm ci --ignore-scripts",
  "buildCommand": "npm run build",
  "outputDirectory": "dist/spa",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/spa/index.html"
    }
  ],
  "functions": {
    "api/**/*.ts": {
      "memory": 2048,
      "maxDuration": 30
    }
  }
}
