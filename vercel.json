{
  "version": 2,
  "buildCommand": "npm run build:client && npm run build:server",
  "outputDirectory": "dist/spa",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/dist/spa/index.html" }
  ],
  "functions": {
    "api/**/*.ts": {
      "memory": 1024,
      "maxDuration": 60
    }
  }
}

